{
  "name": "commitcamp",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:platform": "turbo dev --filter=@commitcamp/platform",
    "dev:landing": "turbo dev --filter=@commitcamp/landing",
    "build:platform": "turbo build --filter=@commitcamp/platform",
    "build:landing": "turbo build --filter=@commitcamp/landing",
    "upload:official-products": "node scripts/upload-official-marketplace-files.mjs"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "jszip": "^3.10.1",
    "turbo": "^2.9.4"
  }
}
