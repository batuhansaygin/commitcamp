---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Navbar } from '../../components/Navbar';
import Footer from '../../components/Footer.astro';
import { t as getT } from '../../i18n/translations';
import { config } from '../../config';
import { buildToolPageJsonLd } from '../../lib/seo';

const lang = 'en';
const tr = getT(lang);
const platformUrl = config.platformUrl;

const title = 'AI Code Reviewer — Free Online Tool | CommitCamp';
const description =
  'Analyze code quality, bugs, security, and performance. Try CommitCamp AI Code Reviewer with upgrade options for unlimited usage.';
const canonicalPath = '/tools/ai-code-review/';
const siteOrigin = Astro.site?.origin ?? 'https://commitcamp.com';
const jsonLd = buildToolPageJsonLd(siteOrigin, {
  name: 'CommitCamp AI Code Reviewer',
  description,
  landingPath: canonicalPath,
});
---

<BaseLayout title={title} description={description} lang={lang} canonicalPath={canonicalPath} jsonLd={jsonLd}>
  <Navbar t={tr.nav} lang={lang} platformUrl={platformUrl} client:load />
  <main class="mx-auto max-w-4xl px-4 pt-28 pb-16 md:px-6">
    <h1 class="text-3xl font-bold md:text-4xl">AI Code Reviewer — Free Online Tool</h1>
    <p class="mt-3 text-zinc-500 dark:text-zinc-400">Get bug detection, security checks, performance suggestions, and best-practice feedback with a letter grade report.</p>
    <div class="mt-8 rounded-xl border border-zinc-200 dark:border-zinc-800 p-5">
      <h2 class="text-lg font-semibold">What you get</h2>
      <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-zinc-500 dark:text-zinc-400">
        <li>A-F quality grading</li>
        <li>Bug and security findings</li>
        <li>Performance and maintainability suggestions</li>
      </ul>
    </div>
    <div class="mt-8 flex gap-3">
      <a href={`${platformUrl}/tools/code-review`} class="rounded-lg bg-gradient-to-r from-cyan-500 to-purple-600 px-5 py-3 font-semibold text-white">Open Tool</a>
      <a href={`${platformUrl}/pricing`} class="rounded-lg border border-zinc-300 dark:border-zinc-700 px-5 py-3 font-semibold">See Pricing</a>
    </div>
  </main>
  <Footer t={tr.footer} lang={lang} />
</BaseLayout>
